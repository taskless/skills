{
  "permissions": {
    "allow": [
      "Bash(cat:*)",
      "Bash(date:*)",
      "Bash(echo:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(sort:*)",
      "Bash(tail:*)",
      "Bash(tr:*)",
      "Bash(wc:*)",
      "Bash(xargs sed:*)",
      "Skill(commit)",
      "Skill(commit:*)",
      "WebFetch(domain:developers.cloudflare.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(pnpm:*)",
      "Bash(git -C:*)",
      "Bash(uv run:*)",
      "WebFetch(domain:api.reactrouter.com)",
      "WebFetch(domain:docs.taskless.io)",
      "Bash(git status -u)",
      "mcp__linear__*"
    ],
    "deny": [
      "AskUserQuestion*",
      "Bash(npx:*)",
      "Bash(pnpm dlx @taskless/cli*)",
      "Bash(openspec:*)"
    ],
    "additionalDirectories": ["openspec/*"]
  },
  "read": {
    "deny": [
      "**/*.key",
      "**/*.pem",
      "**/.aws/**",
      "**/.env*",
      "**/.secrets*",
      "**/.ssh/**",
      "**/credentials/**",
      "**/secrets/**"
    ]
  }
}
